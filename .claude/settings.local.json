{
  "permissions": {
    "allow": [
      "Bash(claude mcp *)",
      "mcp__UnityMCP__manage_scene",
      "mcp__UnityMCP__find_gameobjects",
      "mcp__UnityMCP__read_console",
      "mcp__UnityMCP__manage_components",
      "mcp__UnityMCP__execute_code",
      "mcp__UnityMCP__manage_packages",
      "mcp__UnityMCP__manage_gameobject"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/check_architecture.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -Command \"[System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms'); [System.Windows.Forms.MessageBox]::Show('Claude necesita tu atención', 'RUNEFALL Dev')\" 2>/dev/null || notify-send 'RUNEFALL Dev' 'Claude necesita tu atención' 2>/dev/null || osascript -e 'display notification \"Claude necesita tu atención\" with title \"RUNEFALL Dev\"' 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log_session.py"
          }
        ]
      }
    ]
  }
}
